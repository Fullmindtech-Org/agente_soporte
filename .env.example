# ============================================================================
# AGENTE DE SOPORTE — FULLMINDTECH
# Copiar este archivo como .env y completar los valores
# NUNCA commitear el archivo .env
# ============================================================================

# ----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://soporte_user:soporte_pass@localhost:5432/soporte_db"

# ----------------------------------------------------------------------------
# WhatsApp / Gupshup
# ----------------------------------------------------------------------------
GUPSHUP_API_KEY=
GUPSHUP_APP_ID=
GUPSHUP_PHONE_NUMBER=
# URL base de la API de Gupshup (no modificar salvo cambio del proveedor)
GUPSHUP_API_URL=https://api.gupshup.io/sm/api/v1

# Secreto para validar la firma del webhook entrante de Gupshup
GUPSHUP_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Plane (Gestión de tickets)
# ----------------------------------------------------------------------------
PLANE_API_URL=https://api.plane.so/api/v1
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=

# ----------------------------------------------------------------------------
# Uptime / Monitoreo
# ----------------------------------------------------------------------------
UPTIME_API_URL=
UPTIME_API_KEY=

# ----------------------------------------------------------------------------
# LLM — OpenRouter (gateway de modelos)
# ----------------------------------------------------------------------------
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# Modelo a usar por defecto. Ejemplos:
#   anthropic/claude-3-5-sonnet
#   openai/gpt-4o
#   google/gemini-2.0-flash
LLM_MODEL=anthropic/claude-3-5-sonnet

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
