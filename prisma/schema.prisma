generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Channel {
  WHATSAPP
  EMAIL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// Models
// — Clientes, proyectos y contratos viven en Plane.so (no en DB local).
// — Aquí solo guardamos estado conversacional y trazabilidad de tickets.
// ---------------------------------------------------------------------------

/// Preguntas frecuentes con keywords para busqueda del agente
model Faq {
  id        String   @id @default(uuid())
  keywords  String[]
  question  String
  answer    String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Mirror local de tickets creados en Plane.
/// planeCustomerId y planeProjectId son UUIDs de Plane (sin FK local).
model TicketRecord {
  id              String       @id @default(uuid())
  planeTicketId   String?      @unique
  planeCustomerId String
  planeProjectId  String
  channel         Channel
  description     String
  status          TicketStatus @default(OPEN)
  isOverage       Boolean      @default(false)
  planeUrl        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

/// Sesiones de conversacion del agente por numero de telefono/email
model ConversationSession {
  id       String  @id @default(uuid())
  threadId String  @unique
  channel  Channel
  messages Json    @default("[]")
  state    Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
